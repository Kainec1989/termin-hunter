# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# ID чата для уведомлений (узнать у @userinfobot или @getidsbot)
TELEGRAM_CHAT_ID=

# Базовый интервал между проверками в миллисекундах (по умолчанию 4 минуты)
CHECK_INTERVAL_MS=240000

# Случайный разброс ±N миллисекунд перед каждой проверкой (по умолчанию ±20 сек)
JITTER_MS=20000

# Рабочие часы мониторинга (Europe/Berlin). Вне окна — процесс завершается.
WORK_HOURS_START=07:00
WORK_HOURS_END=19:00

# Запускать браузер в headless-режиме (true/false). Для калибровки селекторов: false
HEADLESS=true

# Браузер для bootstrap: chrome (системный Google Chrome) или пусто (Chromium из Playwright)
BROWSER_CHANNEL=chrome

# TTL сессии uid/wsid в миллисекундах (по умолчанию 1 час)
SESSION_TTL_MS=3600000

# Опционально — ручная калибровка без браузера (скопируйте из URL календаря):
# SERVICE_UID=c97bb32a-92b8-41ba-b5c2-f91d0e90019f
# SESSION_WSID=
# BOOKING_URL=
