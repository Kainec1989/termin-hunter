# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# ID чата для уведомлений (узнать у @userinfobot или @getidsbot)
TELEGRAM_CHAT_ID=

# Базовый интервал между проверками в миллисекундах (по умолчанию 4 минуты)
CHECK_INTERVAL_MS=240000

# Случайный разброс ±N миллисекунд перед каждой проверкой (по умолчанию ±20 сек)
JITTER_MS=20000

# Рабочие часы (Europe/Berlin). Игнорируются при AUTO_BOOK+BOOKING_EMAIL или MONITOR_24_7=true
WORK_HOURS_START=07:00
WORK_HOURS_END=19:00

# Запускать браузер в headless-режиме (true/false). Для калибровки селекторов: false
HEADLESS=true

# Браузер для bootstrap: chrome (системный Google Chrome) или пусто (Chromium из Playwright)
BROWSER_CHANNEL=chrome

# Bootstrap: http (быстро, без браузера) | playwright (fallback вручную)
BOOTSTRAP_MODE=http

# Лёгкое обновление wsid через HTTP redirect перед полным re-bootstrap
WSID_REFRESH_ONLY=true

# TTL сессии uid/wsid в миллисекундах (по умолчанию 15 минут)
SESSION_TTL_MS=900000

# Проактивный re-bootstrap при возрасте сессии (по умолчанию 12 минут)
SESSION_REFRESH_MS=720000

# Burst-режим: интервал опроса в окне выброса слотов (Пн/Ср 15:00, Пт 11:00)
BURST_INTERVAL_MS=30000
BURST_JITTER_MS=5000
BURST_WINDOW_MINUTES=45

# Агрессивный burst (smartcjm-sniper): ~30 сек в окне выброса
BURST_AGGRESSIVE=true
BURST_AGGRESSIVE_INTERVAL_MS=30000

# Пауза опроса при HTTP 429 (мс, по умолчанию 5 мин)
RATE_LIMIT_BACKOFF_MS=300000

# Pre-release: ускоренный опрос за N минут до выброса
PRE_RELEASE_MINUTES=5
PRE_RELEASE_INTERVAL_MS=60000

# Pre-bootstrap: обновить сессию за N минут до выброса
PRE_BOOTSTRAP_MINUTES=2

# Держать браузер открытым в burst-окне (только при BOOTSTRAP_MODE=playwright)
BURST_KEEP_BROWSER_OPEN=false

# Авто-бронирование (smartcjm-appointment-sniper)
AUTO_BOOK=false
AUTO_BOOK_DRY_RUN=false
BOOKING_EMAIL=
# При AUTO_BOOK=true по умолчанию: круглосуточный мониторинг и остановка после успешной брони
AUTO_BOOK_STOP_ON_SUCCESS=true
# MONITOR_24_7=true

# Доп. уведомления (inverse/termin, impf-botpy)
# NTFY_TOPIC=termin-hunter
# NTFY_SERVER=https://ntfy.sh
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
# TTS_ON_SLOT=true
# TTS_COMMAND=spd-say

# Опционально — ручная калибровка без браузера (скопируйте из URL календаря):
# SERVICE_UID=c97bb32a-92b8-41ba-b5c2-f91d0e90019f
# SESSION_WSID=
# BOOKING_URL=
