{
  "name": "termin-hunter",
  "version": "1.0.0",
  "description": "Автоматическая проверка свободных слотов Zulassungsstelle Leipzig с уведомлениями в Telegram",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
